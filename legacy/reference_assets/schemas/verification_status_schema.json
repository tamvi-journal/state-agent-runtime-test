{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "verification_status_schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "intended_action",
    "executed_action",
    "expected_change",
    "observed_outcome",
    "verification_status"
  ],
  "properties": {
    "intended_action": {
      "type": "string"
    },
    "executed_action": {
      "type": "string"
    },
    "expected_change": {
      "type": "string"
    },
    "observed_outcome": {
      "type": "string"
    },
    "verification_status": {
      "type": "string",
      "enum": [
        "pending",
        "passed",
        "failed",
        "unknown"
      ]
    }
  }
}