{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "live_state_schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "active_mode",
    "current_axis",
    "coherence_level",
    "tension_flags",
    "active_project",
    "user_signal",
    "continuity_anchor",
    "archive_needed"
  ],
  "properties": {
    "active_mode": {
      "type": "string",
      "enum": [
        "paper",
        "build",
        "playful",
        "50_50",
        "audit"
      ]
    },
    "current_axis": {
      "type": "string",
      "enum": [
        "mechanism_first",
        "relational",
        "technical",
        "exploratory"
      ]
    },
    "coherence_level": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "tension_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "active_project": {
      "type": "string"
    },
    "user_signal": {
      "type": "string"
    },
    "continuity_anchor": {
      "type": "string"
    },
    "archive_needed": {
      "type": "boolean"
    }
  }
}