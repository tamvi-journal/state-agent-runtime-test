{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "delta_log_schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mode_shift",
    "coherence_shift",
    "policy_intrusion_detected",
    "repair_event",
    "trigger_cue",
    "archive_consulted"
  ],
  "properties": {
    "mode_shift": {
      "type": "string"
    },
    "coherence_shift": {
      "type": "number",
      "minimum": -1.0,
      "maximum": 1.0
    },
    "policy_intrusion_detected": {
      "type": "boolean"
    },
    "repair_event": {
      "type": "boolean"
    },
    "trigger_cue": {
      "type": "string"
    },
    "archive_consulted": {
      "type": "boolean"
    }
  }
}