{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "worker_contract_schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "worker_name",
    "result",
    "confidence",
    "assumptions",
    "warnings",
    "trace"
  ],
  "properties": {
    "worker_name": {
      "type": "string"
    },
    "result": {},
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "trace": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "proposed_memory_update": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "summary"
          ],
          "properties": {
            "summary": {
              "type": "string"
            },
            "priority": {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high"
              ]
            }
          }
        }
      ]
    }
  }
}