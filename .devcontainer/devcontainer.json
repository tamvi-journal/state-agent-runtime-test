{
  "name": "state-memory-agent",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/app",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "postCreateCommand": "python -m pip install -r requirements-dev.txt",
  "remoteEnv": {
    "PYTHONPATH": "src",
    "APP_MODE": "dev",
    "APP_HOST": "0.0.0.0",
    "APP_PORT": "8000",
    "LOG_LEVEL": "info",
    "APP_MODULE": "server.fastapi_app:app",
    "APP_RELOAD": "false",
    "WEBHOOK_BASE_PATH": "/webhooks"
  }
}
